# Core API
PORT=3001

# Telegram
TELEGRAM_BOT_TOKEN=

# Azure webhook mode (set these in Azure App Service app settings)
# TELEGRAM_WEBHOOK_URL=https://<your-app-name>.azurewebsites.net
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Optional startup overrides (use only when needed)
# TELEGRAM_FORCE_WEBHOOK=true
# TELEGRAM_FORCE_POLLING=true

# Gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro

# eBird
EBIRD_API_KEY=

# Google Sheets / Drive
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=
