# Core API
PORT=3001

# Telegram
TELEGRAM_BOT_TOKEN=

# ── Webhook mode ─────────────────────────────────────────────────────────────
# Telegram delivers messages to your server via HTTPS POST instead of polling.
#
# Production (Azure App Service):
#   Set TELEGRAM_WEBHOOK_URL to your app's public HTTPS base URL.
#   WEBSITE_HOSTNAME is auto-set by Azure, which enables webhook mode automatically.
#
# Local development (e.g. ngrok / Cloudflare Tunnel):
#   1. Run:  ngrok http 3001
#   2. Copy the https:// forwarding URL into TELEGRAM_WEBHOOK_URL below.
#   3. Set TELEGRAM_FORCE_WEBHOOK=true  (or use the "Backend (webhook)" launch config).
#
# TELEGRAM_WEBHOOK_URL=https://<your-app>.azurewebsites.net
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Optional startup overrides
# TELEGRAM_FORCE_WEBHOOK=true   # force webhook even on localhost
# TELEGRAM_FORCE_POLLING=true   # force polling even on Azure

# Gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro

# eBird
EBIRD_API_KEY=

# Google Sheets / Drive
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=
