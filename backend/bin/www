#!/usr/bin/env node
/**
 * Wildlife Sightings API — HTTP server entry point done
 *
 * Follows the express-generator bin/www convention:
 *   - Resolves and normalises the port
 *   - Creates the HTTP server
 *   - Pre-loads shared resources (eBird taxonomy)
 *   - Handles startup errors and graceful shutdown
 *
 * Start:
 *   node bin/www          (production)
 *   nodemon bin/www       (development)
 */

try {
  require('dotenv').config();
} catch (err) {
  if (err?.code !== 'MODULE_NOT_FOUND') throw err;
  console.warn('[startup] dotenv not installed; continuing with environment variables provided by the host.');
}

const { execSync } = require('child_process');

const http = require('http');
const app = require('../src/app');
const logger = require('../src/utils/logger');
const { createBot } = require('../bots/telegram/bot');
const { initSocket } = require('../src/socket');
const { SheetWatcher } = require('../database/googleSheets/services/sheetWatcher');
const sheetsService = require('../database/googleSheets/services/googleSheetsService');

// ── Port normalisation ────────────────────────────────────────────────────────

function normalizePort(val) {
  const port = parseInt(val, 10);
  if (isNaN(port)) return val;      // named pipe
  if (port >= 0) return port;       // valid number
  return false;
}

const PORT = normalizePort(process.env.PORT || '3001');
app.set('port', PORT);

// ── Create HTTP server ────────────────────────────────────────────────────────

const server = http.createServer(app);

// ── Socket.IO + live sheet watcher ────────────────────────────────────────────

const io = initSocket(server);
const sheetWatcher = new SheetWatcher(sheetsService, io);
sheetWatcher.start();

// ── Start Telegram bot ────────────────────────────────────────────────────────

createBot(app);

// ── Error handler ─────────────────────────────────────────────────────────────

server.on('error', (err) => {
  if (err.syscall !== 'listen') throw err;

  const bind = typeof PORT === 'string' ? `pipe ${PORT}` : `port ${PORT}`;

  switch (err.code) {
    case 'EACCES':
      logger.error(`${bind} requires elevated privileges`);
      process.exit(1);
      break;
    case 'EADDRINUSE':
      logger.warn(`${bind} is already in use — killing existing process and retrying...`);
      try {
        execSync(`lsof -ti :${PORT} | xargs kill -9`);
      } catch (_) { /* nothing was using it */ }
      setTimeout(() => server.listen(PORT), 1000);
      break;
    default:
      throw err;
  }
});

// ── Listening callback ────────────────────────────────────────────────────────

server.on('listening', () => {
  const addr = server.address();
  const bind = typeof addr === 'string' ? `pipe ${addr}` : `port ${addr.port}`;
  logger.info(`Wildlife Sightings API listening on ${bind}`);
});

// ── Graceful shutdown ─────────────────────────────────────────────────────────

function shutdown(signal) {
  logger.info(`Received ${signal}. Shutting down gracefully...`);
  sheetWatcher.stop();
  server.close(() => {
    logger.info('HTTP server closed.');
    process.exit(0);
  });
  // Force-exit after 10 s if connections are still open
  setTimeout(() => process.exit(1), 10_000).unref();
}

process.on('SIGTERM', () => shutdown('SIGTERM'));
process.on('SIGINT',  () => shutdown('SIGINT'));

// ── Start ─────────────────────────────────────────────────────────────────────

server.listen(PORT);
